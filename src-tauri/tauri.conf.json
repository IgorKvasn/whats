{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whats",
  "version": "0.4.0",
  "identifier": "app.whats.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetwork",
    "shortDescription": "Unofficial desktop wrapper for WhatsApp Web",
    "longDescription": "An unofficial third-party desktop wrapper that hosts the WhatsApp Web site in a persistent webview, with a system tray, native notifications, and a settings window. Not affiliated with, endorsed by, or associated with WhatsApp or Meta Platforms, Inc.",
    "linux": {
      "deb": {
        "desktopTemplate": "bundle/linux/whats.desktop.hbs"
      },
      "rpm": {
        "desktopTemplate": "bundle/linux/whats.desktop.hbs"
      }
    },
    "resources": [
      "resources/inject.js",
      "icons/128x128.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
