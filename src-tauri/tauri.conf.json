{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whats",
  "version": "0.1.0",
  "identifier": "app.whats.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WhatsApp",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "visible": false,
        "url": "https://web.whatsapp.com/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
