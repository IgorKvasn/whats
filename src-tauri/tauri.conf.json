{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "whats",
  "version": "0.2.0",
  "identifier": "app.whats.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "desktopTemplate": "bundle/linux/whats.desktop.hbs"
      },
      "rpm": {
        "desktopTemplate": "bundle/linux/whats.desktop.hbs"
      }
    },
    "resources": [
      "resources/inject.js",
      "icons/128x128.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
